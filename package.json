{
  "name": "dsj",
  "private": true,
  "version": "0.10.0",
  "description": "Dissociative System Journal",
  "author": "Front Switch Studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FrontSwitch/dsj.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "DSJ_DB=\"$HOME/Library/Application Support/com.frontswitchstudio.dsj.dev/dsj.db\" tauri dev --config '{\"identifier\":\"com.frontswitchstudio.dsj.dev\",\"productName\":\"DSJ-dev\"}'",
    "dev:test": "DSJ_DB=\"$HOME/Library/Application Support/com.frontswitchstudio.dsj.test/dsj.db\" tauri dev --config '{\"identifier\":\"com.frontswitchstudio.dsj.test\",\"productName\":\"DSJ-test\"}'",
    "dev:test2": "DSJ_DB=\"$HOME/Library/Application Support/com.frontswitchstudio.dsj.test2/dsj.db\" src-tauri/target/debug/dsj",
    "seed:test": "DSJ_DB=\"$HOME/Library/Application Support/com.frontswitchstudio.dsj.test/dsj.db\" node scripts/seed-test-db.cjs",
    "seed:test2": "DSJ_DB=\"$HOME/Library/Application Support/com.frontswitchstudio.dsj.test2/dsj.db\" node scripts/seed-test-db.cjs",
    "seed:load": "node scripts/seed-load-test.cjs",
    "delete:test": "DSJ_DB=\"$HOME/Library/Application Support/com.frontswitchstudio.dsj.test/dsj.db\" node scripts/delete-test-db.cjs",
    "delete:test2": "DSJ_DB=\"$HOME/Library/Application Support/com.frontswitchstudio.dsj.test2/dsj.db\" node scripts/delete-test-db.cjs",
    "sp:anonymize": "node scripts/sp-anonymize.cjs",
    "cap:sync": "npm run build && npx cap sync ios && node scripts/cap-fix-spm.cjs && cd ios/App && pod install",
    "cap:ios": "npm run cap:sync && open -a Xcode ios/App/App.xcworkspace",
    "cap:ios:run": "npm run cap:sync && node scripts/cap-build-run.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@tiptap/extension-mention": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/zxcvbn": "^4.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.12",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "better-sqlite3": "^12.8.0",
    "happy-dom": "^20.8.7",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.1"
  }
}
