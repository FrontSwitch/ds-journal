{
  "name": "social",
  "rules": [
    {
      "name": "conflict",
      "pattern": "\\b(fight|argument|argued|conflict|confronted|yelled|shouted)\\b",
      "responses": ["What was it about?", "What did you say?", "What did you hold back?"],
      "priority": 14,
      "tags": ["social"]
    },
    {
      "name": "guilt",
      "pattern": "\\b(apologized|sorry|guilt|guilty|ashamed|shame)\\b",
      "responses": ["Did it need saying?", "What are you carrying?", "What would be enough?"],
      "priority": 13,
      "tags": ["social", "emotional"]
    },
    {
      "name": "lonely",
      "pattern": "feel\\s+alone|feeling\\s+lonely|so\\s+lonely|\\blonely\\b|\\bisolated\\b|sitting\\s+here\\s+alone|by\\s+myself\\s+again",
      "responses": ["Is the aloneness welcome or not?", "What's missing?", "What kind of connection would help?"],
      "priority": 13,
      "tags": ["social", "emotional"]
    }
  ]
}
